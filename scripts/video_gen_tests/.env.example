# ===========================================
# Video Generation Test Scripts - API Keys
# ===========================================
# Copy this file to .env and fill in your keys
# NEVER commit the .env file!

# Kling AI 3.0
# Get keys at: https://app.klingai.com/global/dev/api-key
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here

# Google Gemini API (used for both Veo 3.1 and Nano Banana image gen)
# Get key at: https://aistudio.google.com (click Key icon top-right)
GEMINI_API_KEY=your_gemini_api_key_here
