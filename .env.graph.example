# Environment variables for Knowledge Graph deployment
# Copy to .env.graph and fill in your values
# Usage: docker compose -f docker-compose.graph.yml --env-file .env.graph up -d

# Required: OpenAI API key (for argument extraction + Pol.is generation)
OPENAI_API_KEY=sk-proj-xxx

# Optional: Google Gemini API (for YouTube video transcription)
GOOGLE_API_KEY=

# Optional: Perplexity API
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# Weaviate (required by backend Settings, but not used by graph module)
WV_URL=placeholder
WV_API_KEY=placeholder

# Ports (change if conflicts with other services)
BACKEND_PORT=9000
FRONTEND_PORT=9001
AGE_PORT=5433

# Database password (change for production!)
AGE_PASSWORD=postgres

# App environment
ENV=dev
LOG_LEVEL=INFO
